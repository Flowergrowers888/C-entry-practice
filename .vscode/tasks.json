{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: g++.exe 构建活动文件",
            "type": "cppbuild",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}\\*.cpp",
                "-o",
                "E:\\VSCODES\\output_exe\\${fileBasenameNoExtension}.exe",
                "-I","E:\\VSCODES\\include","E:\\VSCODES\\lib\\**",
                "-Wno-unknown-pragmas",
                "-leasyx",
                "-lgdi32",
                "-lole32",
                "-lgdiplus"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
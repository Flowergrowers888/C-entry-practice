{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "useEasyx",
            "command": "C:\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/easyxtest.exe",
                "-Wall",
                "-I${workspaceFolder}/include",
                "-L${workspaceFolder}/lib64",
                "-leasyx",
                "-lgdi32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译器: C:\\mingw64\\bin\\g++.exe"
        }
    ]
}
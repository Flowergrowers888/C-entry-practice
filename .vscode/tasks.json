{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "useEasyx",
            "type": "cppbuild",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/easyxtest.exe",
                "-I${workspaceFolder}/include",
                "-L${workspaceFolder}/lib",
                "-Wno-unknown-pragmas",
                "-leasyx",
                "-lgdi32",
                "-lole32",
                "-lgdiplus"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}